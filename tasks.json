{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Kompiluj SFML",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-g", 
                "${file}", 
                "-o", "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-I", "C:/msys64/mingw64/include",
                "-L", "C:/msys64/mingw64/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}