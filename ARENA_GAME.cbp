<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="ARENA_GAME" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/ARENA_GAME" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add directory="sources" />
					<Add directory="include" />
				</Compiler>
				<Linker>
					<Add option="-mwindows" />
					<Add library="sfml-graphics-d" />
					<Add library="sfml-window-d" />
					<Add library="sfml-system-d" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/ARENA_GAME" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add directory="ext/SFML-2.6.2/include" />
		</Compiler>
		<Linker>
			<Add option="-mwindows" />
			<Add library="sfml-graphics" />
			<Add library="sfml-window" />
			<Add library="sfml-system" />
			<Add directory="ext/SFML-2.6.2/lib" />
		</Linker>
		<Unit filename="include/arena.h" />
		<Unit filename="include/button.h" />
		<Unit filename="include/game.h" />
		<Unit filename="include/player.h" />
		<Unit filename="include/settings.h" />
		<Unit filename="include/shop.h" />
		<Unit filename="include/textureMenager.h" />
		<Unit filename="include/theme.h" />
		<Unit filename="include/utils.h" />
		<Unit filename="resources.rc">
			<Option compilerVar="WINDRES" />
		</Unit>
		<Unit filename="sources/arena.cpp" />
		<Unit filename="sources/button.cpp" />
		<Unit filename="sources/game.cpp" />
		<Unit filename="sources/main.cpp" />
		<Unit filename="sources/player.cpp" />
